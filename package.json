{
  "name": "@cuiqg/eslint-config",
  "version": "2.0.2",
  "description": "Tsuiqg's ESLint config",
  "type": "module",
  "license": "UNLICENSED",
  "homepage": "https://github.com/cuiqg/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuiqg/eslint-config.git"
  },
  "author": "Tsuiqg <i@tsuiqg.me>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "release": "bumpp && npm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "eslint": ">=8.23.0"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^1.3.1",
    "@unocss/eslint-plugin": "^0.57.5",
    "eslint-define-config": "^1.24.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-i": "^2.29.0",
    "eslint-plugin-jsdoc": "^46.8.2",
    "eslint-plugin-jsonc": "^2.10.0",
    "eslint-plugin-markdown": "^3.0.1",
    "eslint-plugin-perfectionist": "^2.2.0",
    "eslint-plugin-unicorn": "^49.0.0",
    "eslint-plugin-vue": "^9.18.1",
    "eslint-plugin-yml": "^1.10.0",
    "globals": "^13.23.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^0.5.0",
    "vue-eslint-parser": "^9.3.2",
    "yaml-eslint-parser": "^1.2.2"
  },
  "devDependencies": {
    "bumpp": "^9.2.0",
    "eslint": "^8.53.0",
    "lint-staged": "^15.0.2",
    "prettier": "^3.0.3",
    "simple-git-hooks": "^2.9.0",
    "tsup": "^7.2.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
