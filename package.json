{
  "name": "@cuiqg/eslint-config",
  "version": "2.1.15",
  "description": "ESLint config preset for @cuiqg",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuiqg/eslint-config.git"
  },
  "author": "Tsuiqg <i@tsuiqg.me>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:inspector": "npm run build && npx @eslint/config-inspector build --config eslint-inspector.config.js",
    "dev": "tsup --watch --onSuccess \"npx @eslint/config-inspector --config eslint-inspector.config.js --open false\"",
    "lint": "eslint .",
    "up": "npx taze major -I",
    "prepack": "npm run build",
    "release": "bumpp && npm publish",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@antfu/install-pkg": "^0.4.1",
    "@clack/prompts": "^0.7.0",
    "@eslint/js": "^9.9.1",
    "@stylistic/eslint-plugin": "^2.6.4",
    "@unocss/eslint-plugin": "^0.62.3",
    "eslint-config-flat-gitignore": "^0.1.8",
    "eslint-config-prettier": "^9.1.0",
    "eslint-flat-config-utils": "^0.3.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.1.0",
    "eslint-plugin-jsdoc": "^50.2.2",
    "eslint-plugin-jsonc": "^2.16.0",
    "eslint-plugin-n": "^17.10.2",
    "eslint-plugin-perfectionist": "^3.3.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-regexp": "^2.6.0",
    "eslint-plugin-unicorn": "^55.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "eslint-plugin-yml": "^1.14.0",
    "globals": "^15.9.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^0.5.0",
    "unconfig": "^0.5.5",
    "vue-eslint-parser": "^9.4.3",
    "yaml-eslint-parser": "^1.2.3"
  },
  "devDependencies": {
    "bumpp": "^9.5.2",
    "eslint": "^9.9.1",
    "lint-staged": "^15.2.9",
    "simple-git-hooks": "^2.11.1",
    "tsup": "^8.2.4"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
