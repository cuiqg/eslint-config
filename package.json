{
  "name": "@cuiqg/eslint-config",
  "version": "2.1.29",
  "description": "ESLint config preset for @cuiqg",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuiqg/eslint-config.git"
  },
  "author": "Tsuiqg <i@tsuiqg.me>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:inspector": "npx @eslint/config-inspector build --config eslint-inspector.config.js",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:inspector": "npx @eslint/config-inspector --config eslint-inspector.config.js --open false",
    "prepack": "npm run build",
    "release": "bumpp && npm publish",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^4.2.0",
    "@unocss/eslint-plugin": "^66.1.2",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-flat-config-utils": "^2.1.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.12.2",
    "eslint-plugin-jsdoc": "^50.6.17",
    "eslint-plugin-jsonc": "^2.20.1",
    "eslint-plugin-n": "^17.18.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-toml": "^0.12.0",
    "eslint-plugin-unicorn": "^59.0.1",
    "eslint-plugin-vue": "^10.1.0",
    "eslint-plugin-yml": "^1.18.0",
    "globals": "^16.1.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^1.1.1",
    "toml-eslint-parser": "^0.10.0",
    "unconfig": "^7.3.2",
    "vue-eslint-parser": "^10.1.3",
    "yaml-eslint-parser": "^1.3.0"
  },
  "devDependencies": {
    "bumpp": "^10.1.1",
    "eslint": "^9.27.0",
    "eslint-plugin-pnpm": "^0.3.1",
    "lint-staged": "^16.0.0",
    "simple-git-hooks": "^2.13.0",
    "tsup": "^8.5.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
