{
  "name": "@cuiqg/eslint-config",
  "version": "2.1.9",
  "description": "ESLint config preset for @cuiqg",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuiqg/eslint-config.git"
  },
  "author": "Tsuiqg <i@tsuiqg.me>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:inspector": "npm run build && npx @eslint/config-inspector build",
    "dev": "npx @eslint/config-inspector --config eslint.config.js",
    "lint": "eslint .",
    "prepack": "npm run build",
    "release": "bumpp && npm publish",
    "prepare": "husky"
  },
  "peerDependencies": {
    "eslint": ">=8.23.0"
  },
  "dependencies": {
    "@antfu/install-pkg": "^0.3.3",
    "@clack/prompts": "^0.7.0",
    "@unocss/eslint-plugin": "^0.61.2",
    "eslint-config-flat-gitignore": "^0.1.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-flat-config-utils": "^0.2.5",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^0.5.3",
    "eslint-plugin-jsonc": "^2.16.0",
    "eslint-plugin-n": "^17.9.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unicorn": "^54.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "eslint-plugin-yml": "^1.14.0",
    "globals": "^15.8.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^0.5.0",
    "vue-eslint-parser": "^9.4.3",
    "yaml-eslint-parser": "^1.2.3"
  },
  "devDependencies": {
    "@cuiqg/prettier-config": "^1.1.6",
    "bumpp": "^9.4.1",
    "eslint": "^9.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "tsup": "^8.1.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "prettier": "@cuiqg/prettier-config"
}
