{
  "name": "@cuiqg/eslint-config",
  "version": "1.3.0",
  "description": "Tsuiqg's ESLint Config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuiqg/eslint-config.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Tsuiqg <i@tsuiqg.me>",
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.js --format esm,cjs --clean",
    "stub": "tsup src/index.js --format esm",
    "lint": "npm run stub && eslint ."
  },
  "dependencies": {
    "eslint-plugin-jsdoc": "^46.8.2",
    "eslint-plugin-vue": "^9.18.1",
    "globals": "^13.23.0"
  },
  "peerDependencies": {
    "eslint": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "eslint": "^8.53.0",
    "lint-staged": "^15.0.2",
    "tsup": "^7.2.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
