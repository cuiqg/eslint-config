{
  "name": "@cuiqg/eslint-config",
  "version": "2.1.26",
  "description": "ESLint config preset for @cuiqg",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuiqg/eslint-config.git"
  },
  "author": "Tsuiqg <i@tsuiqg.me>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:inspector": "npx @eslint/config-inspector build --config eslint-inspector.config.js",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:inspector": "npx @eslint/config-inspector --config eslint-inspector.config.js --open false",
    "prepack": "npm run build",
    "release": "bumpp && npm publish",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^2.9.0",
    "@unocss/eslint-plugin": "^66.0.0",
    "eslint-config-flat-gitignore": "^0.3.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-flat-config-utils": "^0.4.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.3.1",
    "eslint-plugin-jsdoc": "^50.4.3",
    "eslint-plugin-jsonc": "^2.16.0",
    "eslint-plugin-n": "^17.11.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-toml": "^0.12.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "eslint-plugin-vue": "^9.29.1",
    "eslint-plugin-yml": "^1.14.0",
    "globals": "^15.11.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^0.5.0",
    "toml-eslint-parser": "^0.10.0",
    "unconfig": "^0.6.0",
    "vue-eslint-parser": "^9.4.3",
    "yaml-eslint-parser": "^1.2.3"
  },
  "devDependencies": {
    "bumpp": "^9.7.1",
    "eslint": "^9.13.0",
    "lint-staged": "^15.2.10",
    "simple-git-hooks": "^2.11.1",
    "tsup": "^8.3.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
