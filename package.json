{
  "name": "@cuiqg/eslint-config",
  "version": "2.1.2",
  "description": "ESLint config preset for @cuiqg",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuiqg/eslint-config.git"
  },
  "author": "Tsuiqg <i@tsuiqg.me>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "npm run build",
    "release": "bumpp && npm publish",
    "prepare": "husky"
  },
  "peerDependencies": {
    "eslint": ">=8.23.0"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^1.3.1",
    "@unocss/eslint-plugin": "^0.57.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-define-config": "^2.1.0",
    "eslint-plugin-command": "^0.2.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-i": "^2.29.0",
    "eslint-plugin-import-x": "^0.5.0",
    "eslint-plugin-jsdoc": "^46.8.2",
    "eslint-plugin-jsonc": "^2.10.0",
    "eslint-plugin-markdown": "^3.0.1",
    "eslint-plugin-n": "^17.5.1",
    "eslint-plugin-perfectionist": "^2.10.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unicorn": "^52.0.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "eslint-plugin-vue": "^9.18.1",
    "eslint-plugin-yml": "^1.10.0",
    "globals": "^13.23.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^0.5.0",
    "vue-eslint-parser": "^9.3.2",
    "yaml-eslint-parser": "^1.2.2"
  },
  "devDependencies": {
    "@cuiqg/prettier-config": "^1.1.3",
    "bumpp": "^9.4.1",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.0.2",
    "prettier": "^3.2.5",
    "tsup": "^7.2.0",
    "tsx": "^4.9.3"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "prettier": "@cuiqg/prettier-config"
}
